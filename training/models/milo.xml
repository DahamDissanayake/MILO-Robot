<!--
  Milo MJCF model - PLACEHOLDER GEOMETRY (plan D.1/D.2).

  Structure is final (torso + 4x 2-DOF legs, position actuators with servo
  lag); the numbers are not. Before serious training, replace:
    * link lengths / body dims from the Sesame CAD (or the community
      Sesame Simulator URDF: https://one-for-all.github.io/sesame-robot-sim/)
    * masses and CoM from weighing the real upgraded robot (Pi + battery
      shift the CoM vs. the ESP32 build)
    * actuator kp / forcerange / timeconst from the measured MG90 step
      response (expect 20-40 ms lag)

  Joint ranges: hips swing +-45 deg from stand, knees +-60 deg. Joint zero =
  stand pose (the env maps policy deltas the same way the Pi does).
-->
<mujoco model="milo">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.004" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.08" armature="0.002" frictionloss="0.02"/>
    <geom friction="1.0 0.005 0.0001" density="400"/>
    <position kp="1.6" forcerange="-0.22 0.22"/> <!-- MG90 ~2.2 kg.cm -->
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.6 0.7 0.9" rgb2="1 1 1" width="32" height="32"/>
    <material name="body" rgba="0.9 0.85 0.75 1"/>
    <material name="leg" rgba="0.35 0.35 0.4 1"/>
  </asset>

  <worldbody>
    <geom name="floor" type="plane" size="5 5 0.1" friction="1.0 0.005 0.0001"/>
    <light pos="0 0 2" dir="0 0 -1"/>

    <body name="torso" pos="0 0 0.09">
      <freejoint/>
      <!-- ~430 g total upgraded robot; most mass in the torso (Pi, battery, boards) -->
      <geom name="chassis" type="box" size="0.06 0.045 0.025" mass="0.30" material="body"/>
      <site name="imu" pos="0 0 0" size="0.005"/>

      <!-- legs: hip swings fore/aft (y-axis hinge), knee lifts the foot -->
      <body name="fl_upper" pos="0.055 0.055 0">
        <joint name="fl_hip" axis="0 0 1" range="-0.785 0.785"/>
        <geom type="capsule" fromto="0 0 0  0 0.03 0" size="0.006" mass="0.015" material="leg"/>
        <body name="fl_lower" pos="0 0.03 0">
          <joint name="fl_knee" axis="1 0 0" range="-1.047 1.047"/>
          <geom type="capsule" fromto="0 0 0  0 0.01 -0.055" size="0.005" mass="0.012" material="leg"/>
          <geom name="fl_foot" type="sphere" pos="0 0.01 -0.055" size="0.007" friction="1.2 0.005 0.0001"/>
        </body>
      </body>

      <body name="fr_upper" pos="0.055 -0.055 0">
        <joint name="fr_hip" axis="0 0 1" range="-0.785 0.785"/>
        <geom type="capsule" fromto="0 0 0  0 -0.03 0" size="0.006" mass="0.015" material="leg"/>
        <body name="fr_lower" pos="0 -0.03 0">
          <joint name="fr_knee" axis="1 0 0" range="-1.047 1.047"/>
          <geom type="capsule" fromto="0 0 0  0 -0.01 -0.055" size="0.005" mass="0.012" material="leg"/>
          <geom name="fr_foot" type="sphere" pos="0 -0.01 -0.055" size="0.007" friction="1.2 0.005 0.0001"/>
        </body>
      </body>

      <body name="rl_upper" pos="-0.055 0.055 0">
        <joint name="rl_hip" axis="0 0 1" range="-0.785 0.785"/>
        <geom type="capsule" fromto="0 0 0  0 0.03 0" size="0.006" mass="0.015" material="leg"/>
        <body name="rl_lower" pos="0 0.03 0">
          <joint name="rl_knee" axis="1 0 0" range="-1.047 1.047"/>
          <geom type="capsule" fromto="0 0 0  0 0.01 -0.055" size="0.005" mass="0.012" material="leg"/>
          <geom name="rl_foot" type="sphere" pos="0 0.01 -0.055" size="0.007" friction="1.2 0.005 0.0001"/>
        </body>
      </body>

      <body name="rr_upper" pos="-0.055 -0.055 0">
        <joint name="rr_hip" axis="0 0 1" range="-0.785 0.785"/>
        <geom type="capsule" fromto="0 0 0  0 -0.03 0" size="0.006" mass="0.015" material="leg"/>
        <body name="rr_lower" pos="0 -0.03 0">
          <joint name="rr_knee" axis="1 0 0" range="-1.047 1.047"/>
          <geom type="capsule" fromto="0 0 0  0 -0.01 -0.055" size="0.005" mass="0.012" material="leg"/>
          <geom name="rr_foot" type="sphere" pos="0 -0.01 -0.055" size="0.007" friction="1.2 0.005 0.0001"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- order matches the firmware channel order: R1 R2 L1 L2 R4 R3 L3 L4 -->
    <position name="R1" joint="fr_hip"/>
    <position name="R2" joint="fr_knee"/>
    <position name="L1" joint="fl_hip"/>
    <position name="L2" joint="fl_knee"/>
    <position name="R4" joint="rr_knee"/>
    <position name="R3" joint="rr_hip"/>
    <position name="L3" joint="rl_hip"/>
    <position name="L4" joint="rl_knee"/>
  </actuator>

  <sensor>
    <gyro name="gyro" site="imu"/>
    <accelerometer name="accel" site="imu"/>
  </sensor>
</mujoco>
